# Casper — Environment Variables
# Copy to .env for local development
# API keys should be entered via the Settings window in the app (stored securely via OS keychain)

# Optional: override API keys for development (insecure — never commit)
# DEEPGRAM_API_KEY=dg_your_key_here
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Electron / Vite
NODE_ENV=development
